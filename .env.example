# Copy to .env for local runs. Never commit real keys.

FIREWORKS_API_KEY=fw_xxx
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
PROVIDER_ORDER=groq,fireworks,openrouter
DESCRIBE_PROVIDER_ORDER=groq,openrouter,fireworks
STYLE_PROVIDER_ORDER=openrouter,groq,fireworks
VLM_MODEL=accounts/fireworks/models/qwen2p5-vl-7b-instruct
VLM_FALLBACK_MODELS=accounts/fireworks/models/qwen2p5-vl-32b-instruct,accounts/fireworks/models/minimax-m3
DIRECT_VIDEO_MODEL=
DIRECT_VIDEO_MAX_SECONDS=60
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MAX_IMAGES=5
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_VLM_MODEL=qwen/qwen3-vl-8b-instruct
DESCRIBE_MAX_TOKENS=700
STYLE_MODEL=accounts/fireworks/models/gemma-3-27b-it
STYLE_LORA=
STYLE_FALLBACK_MODELS=accounts/fireworks/models/minimax-m3
GROQ_STYLE_MODEL=llama-3.3-70b-versatile
OPENROUTER_STYLE_MODEL=qwen/qwen3-vl-8b-instruct
STYLE_MAX_TOKENS=140

# Track 2 submission profile: Verified Scene Gate.
CAPTION_ENGINE=ensemble
PROVIDER_ORDER=openrouter
DESCRIBE_PROVIDER_ORDER=openrouter
STYLE_PROVIDER_ORDER=openrouter
VERIFIED_SCENE_GATE=1
ENSEMBLE_OBSERVERS=openai/gpt-5.5,google/gemini-3.1-pro-preview
VERIFIED_SCENE_MODEL=openai/gpt-5.5
VERIFIED_WRITER_MODEL=anthropic/claude-opus-4.8
VERIFIED_REPAIR_MODEL=anthropic/claude-opus-4.8
VERIFIED_AUDIT=1
VERIFIED_AUDITOR_MODEL=openai/gpt-5.5
ENSEMBLE_WRITER=anthropic/claude-opus-4.8
ENSEMBLE_OBSERVER_TIMEOUT_S=28
ENSEMBLE_WRITER_TIMEOUT_S=28
OPENROUTER_MAX_INFLIGHT=6
OPENROUTER_HTTP_RETRIES=1
OPENROUTER_RETRY_MAX_WAIT_S=2
MAX_CAPTION_CHARS=420

# Local judge proxy. Uses the first provider with an available key.
JUDGE_PROVIDER_ORDER=fireworks,openrouter,groq
GROQ_JUDGE_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
OPENROUTER_JUDGE_MODEL=qwen/qwen3-vl-8b-instruct

# Optional audio transcription via Groq Whisper.
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
AUDIO_TRANSCRIBE_ENABLED=1
WHISPER_MODEL=whisper-large-v3-turbo

NUM_FRAMES=8
FRAME_MAX_EDGE=768
TIMESTAMP_TEXT=1
FRAME_ANCHOR=1
SCENE_DETECT_ENABLED=0
SCENE_THRESHOLD=0.35
MAX_CONCURRENCY=3
PER_TASK_TIMEOUT_S=125
MIN_TASK_START_S=8
GLOBAL_BUDGET_S=535
